# Local development — use Neon Postgres or any PostgreSQL instance.
# Vercel production: provision Neon via Vercel Storage integration (sets DATABASE_URL automatically).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/eyabantu?sslmode=require"

# Session signing — use a long random value in production (e.g. openssl rand -hex 32)
AUTH_SECRET="generate-a-long-random-string-for-production"
