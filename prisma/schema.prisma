generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  STAFF
}

enum StaffAccessLevel {
  NONE
  MANAGEMENT
  ADMINISTRATION
  AGENT
  VIEWER
}

enum MemberStatus {
  ACTIVE
  LAPSED
  DEFAULTED
  PENDING
}

enum PolicyStatus {
  ACTIVE
  PENDING_UNDERWRITER
  LAPSED
  CANCELLED
}

enum ClaimStatus {
  OPEN
  ASSESSING
  APPROVED
  PAID
  DECLINED
}

enum PaymentMethod {
  DEBIT_ORDER
  PAYFAST
  MANUAL
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  members                Member[]
  policies               PolicyApplication[]
  claims                 Claim[]
  funerals               Funeral[]
  driverSchedules        DriverSchedule[]
  employeeSchedules      EmployeeSchedule[]
  venues                 Venue[]
  expenses               Expense[]
  complaints             Complaint[]
  internalAffairCases    InternalAffairCase[]
  activityLogs           ActivityLog[]
  underwriterLinks       UnderwriterLink[]
  paymentGatewaySettings PaymentGatewaySetting[]
  clientApplications     ClientApplication[]
}

model User {
  id               String             @id @default(cuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email            String             @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             UserRole
  staffAccess      StaffAccessLevel   @default(NONE)
  isActive         Boolean            @default(true)
  phone            String?
  jobTitle         String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  activityLogs     ActivityLog[]
  employeeSchedule EmployeeSchedule[] @relation("UserShifts")
  driverShifts     DriverSchedule[]   @relation("DriverUser")
  policiesCreated  PolicyApplication[] @relation("AgentPolicies")
  complaintsFiled  Complaint[]        @relation("ComplaintReporter")
  expensesApproved Expense[]          @relation("ExpenseApprover")
  clientApplications ClientApplication[] @relation("SubmittedApplications")
}

model Member {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policyNumber    String?
  packageCode     String?
  mainMemberName  String
  idNumber        String?
  phone           String?
  email           String?
  address         String?
  monthlyPremium  Float        @default(0)
  status          MemberStatus @default(ACTIVE)
  missedPayments  Int          @default(0)
  lastPaymentAt   DateTime?
  nextDebitAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  beneficiaries Beneficiary[]
  policies      Policy[]
  payments      Payment[]
  claims        Claim[]
  funerals      Funeral[]
}

model Beneficiary {
  id           String @id @default(cuid())
  memberId     String
  member       Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fullName     String
  relationship String
  sharePercent Int    @default(100)
}

model Policy {
  id             String       @id @default(cuid())
  memberId       String
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  productName    String
  coverAmount    Float
  status         PolicyStatus @default(ACTIVE)
  underwriterRef String?
  effectiveAt    DateTime     @default(now())
}

model PolicyApplication {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentUserId    String?
  agent          User?        @relation("AgentPolicies", fields: [agentUserId], references: [id])
  applicantName  String
  idNumber       String?
  phone          String?
  proposedCover  Float
  monthlyPremium Float
  status         PolicyStatus @default(PENDING_UNDERWRITER)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  memberId      String
  member        Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount        Float
  packageCode   String?
  method        PaymentMethod
  status        PaymentStatus @default(COMPLETED)
  receiptNumber String        @unique
  externalRef   String?
  receivedAt    DateTime      @default(now())
}

model Claim {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status     ClaimStatus @default(OPEN)
  amount     Float?
  reference  String?
  notes      String?
  submittedAt DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Funeral {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId     String?
  member       Member?  @relation(fields: [memberId], references: [id])
  deceasedName String
  funeralDate  DateTime?
  venueId      String?
  venue        Venue?   @relation(fields: [venueId], references: [id])
  status       String   @default("PLANNED")
  coordinator  String?
  createdAt    DateTime @default(now())
}

model DriverSchedule {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  driverUserId String?
  driver       User?    @relation("DriverUser", fields: [driverUserId], references: [id])
  vehicle      String?
  startAt      DateTime
  endAt        DateTime
  routeNotes   String?
}

model EmployeeSchedule {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("UserShifts", fields: [userId], references: [id], onDelete: Cascade)
  shiftStart DateTime
  shiftEnd   DateTime
  location   String?
}

model Venue {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  capacity  Int?
  funerals  Funeral[]
}

model Expense {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      String
  amount        Float
  description   String?
  incurredAt    DateTime @default(now())
  approvedById  String?
  approvedBy    User?    @relation("ExpenseApprover", fields: [approvedById], references: [id])
}

model Complaint {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject       String
  body          String
  status        String   @default("OPEN")
  createdById   String?
  createdBy     User?    @relation("ComplaintReporter", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
}

model InternalAffairCase {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title          String
  severity       String
  status         String   @default("OPEN")
  reporterUserId String?
  details        String
  createdAt      DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}

model UnderwriterLink {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider   String
  externalId String?
  isActive   Boolean @default(true)
}

model PaymentGatewaySetting {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider   String
  merchantId String?
  passphrase String?
  isSandbox  Boolean @default(true)
}

model ClientApplication {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedById     String?
  submittedBy       User?    @relation("SubmittedApplications", fields: [submittedById], references: [id])
  reference         String   @unique
  status            String   @default("SUBMITTED")

  surname           String
  firstName         String
  idNumber          String?
  employeeNumber    String?
  employerName      String?
  maritalStatus     String?
  email             String?
  cellphone         String?
  address           String?
  addressCode       String?
  inceptionDate     DateTime?
  groupBranch       String?

  packageCode       String?
  addonCodes        String?
  extendedPremium   Float    @default(0)
  totalPremium      Float    @default(0)

  accountHolder     String?
  accountNumber     String?
  bankName          String?
  branchName        String?
  branchCode        String?
  accountType       String?
  debitDay          String?

  spousesJson       String?
  dependantsJson    String?
  beneficiariesJson String?

  declarationAccepted Boolean @default(false)
  popiaAccepted       Boolean @default(false)
  signatureName       String?
  signedAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, createdAt])
}
